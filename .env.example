# City_Sim configuration — copy to .env and fill in, or export these in your shell.
# All values are optional; the app runs out of the box with the defaults below.

# ── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret. The default is for local dev ONLY — set a strong random
# value in any real deployment.
CITY_SIM_SECRET=dev-secret-change-me

# ── LLM provider (for live faction negotiation audiences) ────────────────────
# Leave as "stub" to use the built-in canned responses (no API key, no network).
# Options: stub | anthropic | openai_compat
LLM_PROVIDER=stub

# Required when LLM_PROVIDER is anthropic or openai_compat:
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-sonnet-4-6

# Required for openai_compat (Ollama, LM Studio, OpenAI, etc.):
# LLM_BASE_URL=http://localhost:11434/v1

# Optional tuning:
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=500
# LLM_TIMEOUT=30
